# Port the API listens on (Render sets this automatically in production).
PORT=4000
# Allowed CORS origin for the frontend.
# Local dev:
CORS_ORIGIN=http://localhost:3000
# Production (Render): set to your deployed frontend URL, e.g.
# CORS_ORIGIN=https://travelvn.onrender.com

# MongoDB connection string. If empty, data is stored in data/app-store.json (local dev).
# Get this from MongoDB Atlas (free): https://www.mongodb.com/cloud/atlas
# MONGODB_URI=mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
# MONGODB_DB=travelvn
